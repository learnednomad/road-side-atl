-- ── Diagnostics: keep current 1800-2000 bp range, normalize to 2000 ─────────
UPDATE services SET "commissionRate" = 2000, "updatedAt" = NOW()
  WHERE category = 'diagnostics' AND "commissionRate" <> 2000;

