   55000, 'mechanics', 'scheduled', 2000,
   '[{"category":"Starter","items":["Cranking Voltage","Solenoid Click","Wiring Continuity","Ground Connection"]}]'::jsonb, true, NOW(), NOW()),

  (gen_random_uuid()::text, 'A/C Diagnostic + Recharge', 'ac-recharge',
