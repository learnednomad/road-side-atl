-- DRAFT — REVIEW BEFORE APPLYING
-- Aligns existing prod service prices + commission rates to 2026 Atlanta market
-- benchmarks (see docs/atlanta_vehicle_service_cost_deep_dive (1).md and
-- memory: project_atlanta_pricing_2026.md).
--
-- Safety:
--   * bookings table snapshots estimatedPrice/finalPrice at creation, so this
--     migration does NOT affect existing bookings.
--   * Apply during low-traffic window so customers don't see prices change
--     mid-flow.
--
-- How to apply (the "0031"/"0030" in this filename is NOT a journal index — the
-- squash baseline reset the counter; the next real drizzle index is 0021):
--   * Do NOT rename this to 0030_*.sql / 0031_*.sql — that would create a journal
--     numbering gap and diverge from the squashed history.
--   * Run `drizzle-kit generate` and merge this SQL into the generated 0021_*.sql,
--     converting it to drizzle format: drop the BEGIN/COMMIT wrapper (drizzle-kit
--     does NOT use transaction wrappers) and separate statements with
--     `--> statement-breakpoint` comments instead. OR apply it as a standalone
--     data migration outside drizzle.

BEGIN;

-- ── Mechanics: update existing services to mid-of-band Atlanta pricing ──────
UPDATE services SET "basePrice" = 21500, "commissionRate" = 2200, "updatedAt" = NOW()
  WHERE slug = 'battery-replace';

UPDATE services
  SET "basePrice" = 27500,
      "commissionRate" = 2000,
      name = 'Brake Service (Pads, 1 Axle)',
      description = 'Brake pad replacement on one axle. Includes rotor inspection and brake fluid check. Rotor replacement quoted separately if needed.',
      "updatedAt" = NOW()
  WHERE slug = 'brake-service';

UPDATE services SET "commissionRate" = 2200, "updatedAt" = NOW() WHERE slug = 'oil-change';
UPDATE services SET "commissionRate" = 2000, "updatedAt" = NOW() WHERE slug = 'belt-replacement';
UPDATE services SET "commissionRate" = 2200, "updatedAt" = NOW() WHERE slug = 'general-maintenance';

UPDATE services
  SET "basePrice" = 45000,
      "commissionRate" = 2000,
      description = 'Air conditioning component repair (compressor, condenser, expansion valve). Includes diagnostic and recharge.',
      "updatedAt" = NOW()
  WHERE slug = 'ac-repair';

-- ── Mechanics: insert new services that didn't exist before ─────────────────
INSERT INTO services (id, name, slug, description, "basePrice", category, "schedulingMode", "commissionRate", "checklistConfig", active, "createdAt", "updatedAt")
