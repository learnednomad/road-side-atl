   '[{"category":"Suspension","items":["Strut/Shock Condition","Bushing Wear","Ball Joint Play","Control Arm Integrity"]}]'::jsonb, true, NOW(), NOW()),

  (gen_random_uuid()::text, 'Tune-Up / Ignition Service', 'tune-up',
