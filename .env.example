# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/roadside_atl

# Auth.js
AUTH_SECRET=generate-a-secret-with-openssl-rand-base64-32
AUTH_GOOGLE_ID=your-google-client-id
AUTH_GOOGLE_SECRET=your-google-client-secret
AUTH_URL=http://localhost:3000

# Stripe (fallback payment)
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx

# Business Info
NEXT_PUBLIC_CASHAPP_TAG=$RoadsideGA
NEXT_PUBLIC_ZELLE_INFO=pay@roadsidega.com
NEXT_PUBLIC_BUSINESS_PHONE=(404) 555-0199
NEXT_PUBLIC_BUSINESS_NAME=RoadSide GA

# Google Maps
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your-google-maps-api-key
GOOGLE_MAPS_API_KEY_SERVER=your-google-maps-server-api-key

# Auto-Dispatch
AUTO_DISPATCH_ENABLED=true
MAX_DISPATCH_DISTANCE_MILES=50

# Twilio (SMS notifications)
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+1your-twilio-phone-number

# Resend (email notifications)
RESEND_API_KEY=re_your-resend-api-key
RESEND_FROM=noreply@roadsidega.com

# Sentry (error tracking - optional)
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=

# Admin email (for seeding)
ADMIN_EMAIL=admin@example.com
# Required to seed admin users — no default (min 12 chars). Seeding fails without it.
ADMIN_PASSWORD=
# Must be "true" to allow the (destructive) seed to run in production (APP_ENV=production).
# Guards against a stray SEED_DB=true wiping the production database.
ALLOW_PROD_SEED=false
# One-time only: set true for a SINGLE deploy to adopt an existing (push-provisioned)
# database onto the squashed migration baseline (syncs schema via push, then marks
# the baseline applied). Remove it after that deploy. Fresh DBs don't need it.
DB_ADOPT_BASELINE=false

# Server config
# Set TRUST_PROXY=true when running behind a reverse proxy (Coolify/Traefik,
# nginx, Cloudflare) so X-Forwarded-For / X-Real-IP are honored for per-client
# rate limiting. If left false behind a proxy, the app only sees the proxy IP
# and rate limiting fails open (no limit) rather than throttling all users.
TRUST_PROXY=false
# Slack Incoming Webhook URL for ops alerts (failed payouts, disputes, clawbacks,
# deadline suspends). Optional — alerts are no-ops if unset.
SLACK_OPS_WEBHOOK_URL=
LOG_LEVEL=info
DISABLE_CRON=false
SEED_DB=false

# ── Novu notifications (self-hosted: https://novu.roadsidega.com) ─────────────
# Master switch. When != "true", the Novu adapter is a no-op and only the
# legacy Resend/Twilio/web-push senders run. Flip to "true" per environment
# once the workflows are seeded and verified.
NOVU_ENABLED=false
# Per-environment API key — Novu dashboard → Settings → API Keys (one per env).
NOVU_SECRET_KEY=
NOVU_API_URL=https://novu-api.roadsidega.com
# Front-end <Inbox> (public). APP_ID = the environment "applicationIdentifier".
NEXT_PUBLIC_NOVU_APP_ID=
NEXT_PUBLIC_NOVU_BACKEND_URL=https://novu-api.roadsidega.com
NEXT_PUBLIC_NOVU_SOCKET_URL=https://novu-ws.roadsidega.com
